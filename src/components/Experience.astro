---
const experiences = [
  {
    role: "AI Engineer",
    company: "Order.co",
    companyUrl: "https://www.order.co",
    period: "May — Aug 2026",
    highlights: [
      "Built offline evals for live offers that raised core product field accuracy to <b>95%</b>",
      "Shipped an inline LLM-as-judge online eval sampling <b>~10%</b> of live parses for real-time, per-field accuracy monitoring in production",
      "Built a retry/fallback system with bot-block detection and jittered backoff for the vendor product-data scraper, raising recovery from <b>0%</b> to <b>82.7%</b> and overall success above <b>98%</b>",
    ],
    tags: ["Python", "AI/ML", "LLM Evaluations", "Data Extraction", "Prompt Engineering"],
  },
  {
    role: "AI Engineer",
    company: "Generative AI at Cornell",
    companyUrl: "https://www.cornellgenai.dev/",
    period: "Feb 2026 — Present",
    highlights: [
      "Built an ingestion pipeline that discovers, dedupes, and scrapes news across <b>14+ providers</b> into a clustered event model",
      "Built a graph-backed LLM analysis pipeline for <b>Investcorp</b> to classify events, extract geographic context, and assess credit and covenant impacts",
    ],
    tags: ["Python", "TypeScript", "AI Agents", "Anthropic API", "ESG Analytics", "Graph Databases"],
  },
  {
    role: "Undergraduate Researcher",
    company: "Cornell University",
    companyUrl: "https://www.orie.cornell.edu",
    period: "Jan 2026 — Present",
    highlights: [
      "Developing <b>deep reinforcement learning</b> models to optimize complex queueing network systems",
      "Applying AI techniques to operations research problems",
    ],
    tags: ["Reinforcement Learning", "PPO", "PyTorch", "Operations Research", "Queueing Theory", "Python"],
  },
  {
    role: "Financial Software Engineer",
    company: "Cornell FinTech Club",
    companyUrl: "https://www.cornellfintechclub.com/",
    period: "Jan 2026 — Present",
    highlights: [
      "Built a fintech lending platform with <b>Next.js, FastAPI, and PostgreSQL</b> featuring ML-powered credit scoring",
      "Implemented credit decisioning engine using logistic regression and gradient boosting models",
    ],
    tags: ["Next.js", "FastAPI", "PostgreSQL", "scikit-learn", "TypeScript", "Docker"],
  },
  {
    role: "Research Assistant",
    company: "University of Pennsylvania",
    companyUrl: "https://www.law.upenn.edu",
    period: "Jun — Aug 2025",
    highlights: [
      "Scraped, cleaned, and pipelined data from websites, Excel files, and PDFs using Python and NumPy",
      "Produced organized CSV datasets for research analysis, streamlining the data processing workflow",
    ],
    tags: ["Python", "Pandas", "ETL", "Data Analysis", "Web Scraping", "PDF Parsing"],
  },
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="section-label reveal"><span class="idx">02 /</span> Experience</div>
    <h2 class="section-title reveal reveal-delay-1">Where I've been training.</h2>

    <div class="exp-list">
      {experiences.map((exp, i) => (
        <div class={`exp-item reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="exp-left">
            <span class="exp-period">{exp.period}</span>
          </div>
          <div class="exp-content">
            <div class="exp-header">
              <h3 class="exp-role">{exp.role}</h3>
              <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="exp-company">
                {exp.company}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
            <ul class="exp-highlights">
              {exp.highlights.map(h => (
                <li set:html={h} />
              ))}
            </ul>
            <div class="exp-tags">
              {exp.tags.map(tag => (
                <span class="exp-tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    border-top: 1px solid var(--border-color);
  }

  .exp-list {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 2.5rem;
    padding: 1.875rem 0;
    border-top: 1px solid var(--border-color);
  }

  .exp-item:last-child {
    border-bottom: 1px solid var(--border-color);
  }

  .exp-left {
    padding-top: 0.15rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .exp-header {
    margin-bottom: 0.75rem;
  }

  .exp-role {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .exp-company {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.875rem;
    color: var(--accent);
    margin-top: 0.15rem;
  }

  .exp-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .exp-highlights li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .exp-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .exp-highlights li :global(b) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .exp-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: var(--bg-card);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  @media (max-width: 768px) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
