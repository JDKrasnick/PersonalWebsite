---
const experiences = [
  {
    role: "Undergraduate Researcher",
    company: "Cornell University",
    companyUrl: "https://www.orie.cornell.edu",
    period: "Jan 2026 — Present",
    description: "Conducting research on deep reinforcement learning applications for queueing network optimization under Professor Jim Dai at Cornell's Operations Research & Information Engineering department. Currently looking at using a PPO-based algorithm for optimizing hospital networks.",
    highlights: [
      "Developing deep RL models to optimize complex queueing network systems",
      "Applying AI techniques to operations research problems",
    ],
    tags: ["Deep Learning", "Reinforcement Learning", "Pytorch", "Operations Research", "Python"],
  },
  {
    role: "Research Assistant",
    company: "University of Pennsylvania",
    companyUrl: "https://www.law.upenn.edu",
    period: "Jun — Aug 2025",
    description: "Conducted research under Professor Jonathan Klick at the University of Pennsylvania Law School, focusing on data collection and analysis for legal research.",
    highlights: [
      "Scraped, cleaned, and pipelined data from websites, Excel files, and PDFs using Python and NumPy",
      "Produced organized CSV datasets for research analysis, streamlining the data processing workflow",
    ],
    tags: ["Python", "NumPy", "Pandas", "ETL", "Data Analysis", "Web Scraping"],
  },
  {
    role: "Financial Software Engineer",
    company: "Cornell FinTech Club",
    companyUrl: "https://www.cornellfintechclub.com/",
    period: "Jan 2026 — Present",
    description: "Building financial technology solutions and quantitative analysis tools as part of Cornell's premier fintech student organization.",
    highlights: [
      "Contributing to fintech projects and collaborating with fellow engineers",
    ],
    tags: ["Python", "Financial Analysis", "Software Engineering"],
  },
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="section-label reveal">Experience</div>
    <h2 class="section-title reveal reveal-delay-1">Where I've Worked</h2>

    <div class="exp-list">
      {experiences.map((exp, i) => (
        <div class={`exp-item reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="exp-left">
            <span class="exp-period">{exp.period}</span>
          </div>
          <div class="exp-content">
            <div class="exp-header">
              <h3 class="exp-role">{exp.role}</h3>
              <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="exp-company">
                {exp.company}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
            <p class="exp-desc">{exp.description}</p>
            <ul class="exp-highlights">
              {exp.highlights.map(h => (
                <li>{h}</li>
              ))}
            </ul>
            <div class="exp-tags">
              {exp.tags.map(tag => (
                <span class="exp-tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    border-top: 1px solid var(--border-color);
  }

  .exp-list {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 3rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .exp-item:first-child {
    border-top: 1px solid var(--border-color);
  }

  .exp-left {
    padding-top: 0.15rem;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .exp-header {
    margin-bottom: 0.75rem;
  }

  .exp-role {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .exp-company {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.875rem;
    color: var(--accent);
    margin-top: 0.15rem;
  }

  .exp-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .exp-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .exp-highlights li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .exp-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .exp-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 768px) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
