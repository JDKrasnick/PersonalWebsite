<section class="hero" id="hero">
  <canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-hud" aria-hidden="true">
    epoch <b id="hero-epoch">000</b><br />
    loss <b id="hero-lossv">0.000</b><br />
    accuracy <b id="hero-accuracy">0.50</b><br />
    status <b>learning</b>
    <svg class="hero-progress" viewBox="0 0 112 30" aria-hidden="true">
      <path d="M1 28.5H111" />
      <polyline id="hero-loss-chart" points="" />
    </svg>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-name reveal reveal-delay-1">JD Krasnick</h1>
      <p class="hero-desc reveal reveal-delay-2">
        AI/ML engineer &amp; builder — from <span class="hl">classical ML</span> to
        <span class="hl">modern LLMs</span>, I ship systems that learn from, augment, and act on real-world data.
      </p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="#projects" class="btn btn-primary">
          View Projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <a href="#contact" class="btn btn-outline">Get in Touch</a>
      </div>
      <div class="hero-socials reveal reveal-delay-4">
        <a href="https://github.com/JDKrasnick" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-link">
