<section class="hero" id="hero">
  <!-- Ambient background -->
  <div class="hero-bg">
    <div class="hero-glow"></div>
  </div>

  <div class="container hero-centered">
    <div class="hero-content">
      <div class="hero-badge reveal">
        <span class="status-dot"></span>
        Open to opportunities
      </div>
      <h1 class="hero-name reveal reveal-delay-1">
        JD Krasnick
      </h1>
      <p class="hero-title reveal reveal-delay-2">Software Engineer</p>
      <p class="hero-desc reveal reveal-delay-3">
        Curiosity-driven engineer building clean software.<br />
        From ML to full-stack, I love exploring what's possible.
      </p>
      <div class="hero-actions reveal reveal-delay-4">
        <a href="#projects" class="btn btn-primary">
          View Projects
