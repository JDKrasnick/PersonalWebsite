      </div>
    </div>
  </div>

  <div class="scroll-indicator reveal reveal-delay-4">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 0;
    background:
      radial-gradient(80% 100% at 78% 50%, rgba(70, 92, 210, 0.14) 0%, transparent 62%),
      radial-gradient(68% 80% at 68% 60%, rgba(255, 180, 84, 0.07) 0%, transparent 58%),
      var(--bg-primary);
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
    cursor: crosshair;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* Text receives its own calm pocket without masking the full surface. */
    background:
      linear-gradient(to right, rgba(7, 7, 10, 0.82) 0%, rgba(7, 7, 10, 0.67) 37%, rgba(7, 7, 10, 0.22) 59%, transparent 78%),
      radial-gradient(120% 100% at 51% 46%, transparent 28%, rgba(7, 7, 10, 0.3) 82%, var(--bg-primary) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
  }

  .hero-hud {
    position: absolute;
    top: 100px;
    right: 2rem;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    text-align: right;
    line-height: 2;
    letter-spacing: 0.04em;
  }
  .hero-hud b {
    color: var(--accent-data);
    font-weight: 500;
  }
  .hero-progress {
    display: block;
    width: 112px;
    height: 30px;
    margin: 0.45rem 0 0 auto;
    overflow: visible;
  }
  .hero-progress path {
    fill: none;
    stroke: rgba(255, 255, 255, 0.14);
    stroke-width: 1;
  }
  .hero-progress polyline {
    fill: none;
    stroke: var(--accent-data);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .hero-content {
    max-width: 620px;
    display: flex;
    flex-direction: column;
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.98;
    color: var(--text-primary);
  }

  .hero-desc {
    margin-top: 1.125rem;
    font-size: clamp(1.0625rem, 2.4vw, 1.375rem);
    color: var(--text-primary);
    font-weight: 400;
    max-width: 620px;
    letter-spacing: -0.01em;
    line-height: 1.6;
  }

  .hero-desc .hl {
    color: var(--accent);
  }

  .hero-actions {
    margin-top: 2.125rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-socials {
    margin-top: 1.625rem;
    display: flex;
    gap: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }
  .social-link:hover {
    color: var(--accent);
    background: var(--bg-card);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }

  .scroll-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, var(--text-muted), transparent);
    animation: scroll-pulse 2.5s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.15; }
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
    }
    .hero-hud {
      display: none;
    }
    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  import { initHero } from '../scripts/hero-gradient';
  import { initHeroLifecycle, prefersReducedMotion, isLowPowerMobile } from '../scripts/hero-lifecycle';

  const canvas = document.getElementById('hero-canvas');
  const heroSection = document.getElementById('hero');

  if (canvas instanceof HTMLCanvasElement && heroSection) {
    const handle = initHero(canvas, {
      reducedMotion: prefersReducedMotion(),
      mobile: isLowPowerMobile(),
    });
    initHeroLifecycle(heroSection, handle);
  }
</script>
