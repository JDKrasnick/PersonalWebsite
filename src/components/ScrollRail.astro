---
interface Props {
  topLabel?: string;
  bottomLabel?: string;
}

const { topLabel = "loss 1.00", bottomLabel = "min" } = Astro.props;
---

<div class="rail" aria-hidden="true">
  <span class="cap top">{topLabel}</span>
  <div class="marker" id="rail-marker"></div>
  <span class="cap bot">{bottomLabel}</span>
</div>

<style>
  .rail {
    position: fixed;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    height: 220px;
    width: 2px;
    background: var(--border-color);
    z-index: 40;
    border-radius: 2px;
  }

  .marker {
    position: absolute;
    left: 50%;
    top: 0;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent-data);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 14px 3px rgba(255, 180, 84, 0.5);
  }

  .cap {
    position: absolute;
    left: 14px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-muted);
    white-space: nowrap;
    letter-spacing: 0.08em;
  }
  .cap.top {
    top: -6px;
  }
  .cap.bot {
    bottom: -6px;
  }

  @media (max-width: 900px) {
    .rail {
      display: none;
    }
  }
</style>
