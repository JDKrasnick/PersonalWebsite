---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "JD Krasnick | AI/ML Engineer",
  description = "JD Krasnick is an AI/ML engineer building reliable machine learning systems, LLM applications, and data-driven products.",
  image = "/og-image.png",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://www.jdkrasnick.com";
const canonicalUrl = new URL(Astro.url.pathname, `${siteUrl}/`).toString();
const imageUrl = new URL(image, `${siteUrl}/`).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "JD Krasnick",
      url: siteUrl,
      jobTitle: "AI/ML Engineer",
      description,
      email: "mailto:jdkrasnick@gmail.com",
      sameAs: [
        "https://github.com/JDKrasnick",
        "https://www.linkedin.com/in/john-j-d-krasnick-a62419287/",
      ],
      knowsAbout: [
        "Machine Learning",
        "Large Language Models",
        "Artificial Intelligence",
        "Data Engineering",
        "Full-stack Development",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "JD Krasnick",
      description,
      publisher: { "@id": `${siteUrl}/#person` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="JD Krasnick" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1730" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:alt" content="JD Krasnick, AI/ML Engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="JD Krasnick, AI/ML Engineer" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
